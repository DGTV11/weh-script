# closures test

func outer(x) 
  func inner(y) => x+y
  return inner
end 

var x=10
var closure = outer(x)
print(x)
print(" + 5 = ")
println(closure(5))
print(x)
print(" + 5 = ")
println(closure(20))

func count(initial)
  var x=initial
  func inc() => nonlocal x=x+1
  return inc
end

var closure2=count(100)
println(closure2())
println(closure2())
println(closure2())
